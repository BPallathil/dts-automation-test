{
  "name": "dts-test-automation",
  "version": "1.0.0",
  "description": "Login test automation framework using Selenium WebDriver + Mocha",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 30000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=test-report"
  },
  "dependencies": {
    "selenium-webdriver": "^4.27.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "mochawesome": "^7.1.3"
  }
}
